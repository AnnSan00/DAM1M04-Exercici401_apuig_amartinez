<div class="container">
    <h2>Registrar Nou Client</h2>

    <form action="/create" method="POST" id="formClient">
        <input type="hidden" name="taula" value="clients">

        <div class="form-group">
            <label>Nom Complet:</label>
            <input type="text" name="name" id="name" placeholder="Ex: Joan Garcia">
            <span class="error-msg" id="error-name"></span>
        </div>

        <div class="form-group">
            <label>Correu Electrònic:</label>
            <input type="text" name="email" id="email" placeholder="correu@exemple.com">
            <span class="error-msg" id="error-email"></span>
        </div>

        <div class="form-group">
            <label>Telèfon:</label>
            <input type="text" name="phone" id="phone" placeholder="600000000">
            <span class="error-msg" id="error-phone"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Crear Client</button>
            <a href="/clients" class="btn btn-toggle">Cancel·lar</a>
        </div>
    </form>
</div>