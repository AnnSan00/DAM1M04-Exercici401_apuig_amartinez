<div class="container">
    <h2>Editar Producte</h2>

    <form action="/Update" method="POST" id="formProducte">
        <input type="hidden" name="taula" value="productes">
        <input type="hidden" name="id" value="{{producte.id}}">

        <div class="form-group">
            <label>Nom:</label>
            <input type="text" name="name" id="name" value="{{producte.name}}">
            <span class="error-msg" id="error-name"></span>
        </div>

        <div class="form-group">
            <label>Categoria:</label>
            <input type="text" name="category" id="category" value="{{producte.category}}">
            <span class="error-msg" id="error-category"></span>
        </div>

        <div class="form-group">
            <label>Preu (€):</label>
            <input type="number" step="0.01" name="price" id="price" value="{{producte.price}}">
            <span class="error-msg" id="error-price"></span>
        </div>

        <div class="form-group">
            <label>Stock:</label>
            <input type="number" name="stock" id="stock" value="{{producte.stock}}">
            <span class="error-msg" id="error-stock"></span>
        </div>

        <div class="form-group">
            <label>Actiu:</label>
            <select name="active">
                <option value="1" {{#if producte.active}}selected{{/if}}>Sí</option>
                <option value="0" {{#unless producte.active}}selected{{/unless}}>No</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Guardar Canvis</button>
            <button type="submit" formaction="/Delete" class="btn btn-delete" onclick="return confirm('Segur?')">Esborrar</button>
        </div>
    </form>
</div>