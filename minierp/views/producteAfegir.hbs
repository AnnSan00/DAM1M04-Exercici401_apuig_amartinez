<div class="container">
    <h2>Afegir Nou Producte</h2>

    <form action="/create" method="POST" id="formProducte">
        <input type="hidden" name="taula" value="productes">

        <div class="form-group">
            <label for="name">Nom del Producte:</label>
            <input type="text" name="name" id="name" placeholder="Ex: Teclat Mecànic">
            <span class="error-msg" id="error-name"></span>
        </div>

        <div class="form-group">
            <label for="category">Categoria:</label>
            <input type="text" name="category" id="category" placeholder="Ex: Perifèrics">
            <span class="error-msg" id="error-category"></span>
        </div>

        <div class="form-group">
            <label for="price">Preu (€):</label>
            <input type="number" step="0.01" name="price" id="price" placeholder="0.00">
            <span class="error-msg" id="error-price"></span>
        </div>

        <div class="form-group">
            <label for="stock">Stock Inicial:</label>
            <input type="number" name="stock" id="stock" placeholder="0">
            <span class="error-msg" id="error-stock"></span>
        </div>

        <div class="form-group">
            <label for="active">Estat:</label>
            <select name="active" id="active">
                <option value="1">Actiu (Visible a la botiga)</option>
                <option value="0">Inactiu</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Crear Producte</button>
            <a href="/productes" class="btn btn-toggle">Cancel·lar</a>
        </div>
    </form>
</div>